<!--
  templateType: page
  isAvailableForNewContent: true
  label: Home
  screenshotPath: ../images/template-previews/home.png
-->
{% extends "./layouts/base.html" %}

{% block body %}

{% dnd_area "dnd_area"
  label="Main section",
  class="body-container body-container--home"
%}

  {# Hero Section #}
  {% dnd_section
    vertical_alignment="MIDDLE"
  %}
    {% dnd_column
      width=12,
      offset=0
    %}
      {% dnd_row %}
        {% dnd_module path="../modules/hero-with-background.module" %}
          {% module_attribute "background_type" %}none{% end_module_attribute %}
          {% module_attribute "hero_label" %}Free California Quit Program{% end_module_attribute %}
          {% module_attribute "hero_title" %}Quit Smoking.<br>Quit Vaping.<br>Take Control.{% end_module_attribute %}
          {% module_attribute "hero_description" %}Science-based strategies. Personal coaching. Real results. Get free support to quit tobacco and nicotine for good.{% end_module_attribute %}
          {% module_attribute "primary_button_text" %}📞 Call 800-300-8086{% end_module_attribute %}
          {% module_attribute "primary_button_url" %}tel:8003008086{% end_module_attribute %}
          {% module_attribute "secondary_button_text" %}💬 Start Live Chat{% end_module_attribute %}
          {% module_attribute "secondary_button_url" %}https://helpline-vision.ucsd.edu/Chat{% end_module_attribute %}
        {% end_dnd_module %}
      {% end_dnd_row %}
    {% end_dnd_column %}
  {% end_dnd_section %}

  {# Journey/About Section #}
  {% dnd_section %}
    {% dnd_column
      width=12,
      offset=0
    %}
      {% dnd_row %}
        {% dnd_module path="../modules/journey-timeline.module" %}
        {% end_dnd_module %}
      {% end_dnd_row %}
    {% end_dnd_column %}
  {% end_dnd_section %}

  {# How Coaching Works Section #}
  {% dnd_section %}
    {% dnd_column
      width=12,
      offset=0
    %}
      {% dnd_row %}
        {% dnd_module path="../modules/numbered-features.module" %}
          {% module_attribute "section_label" %}Simple Process{% end_module_attribute %}
          {% module_attribute "section_title" %}How Our Quit Coaching Works{% end_module_attribute %}
          {% module_attribute "columns" %}3{% end_module_attribute %}
        {% end_dnd_module %}
      {% end_dnd_row %}
    {% end_dnd_column %}
  {% end_dnd_section %}

  {# Stats Section #}
  {% dnd_section %}
    {% dnd_column
      width=12,
      offset=0
    %}
      {% dnd_row %}
        {% dnd_module path="../modules/stats-grid-simple.module" %}
        {% end_dnd_module %}
      {% end_dnd_row %}
    {% end_dnd_column %}
  {% end_dnd_section %}

  {# Programs Section #}
  {% dnd_section %}
    {% dnd_column
      width=12,
      offset=0
    %}
      {% dnd_row %}
        {% dnd_module path="../modules/programs-grid.module" %}
          {% module_attribute "section_label" %}Tailored Programs{% end_module_attribute %}
          {% module_attribute "section_title" %}A Program Designed for You{% end_module_attribute %}
        {% end_dnd_module %}
      {% end_dnd_row %}
    {% end_dnd_column %}
  {% end_dnd_section %}

  {# Final CTA Section #}
  {% dnd_section %}
    {% dnd_column
      width=12,
      offset=0
    %}
      {% dnd_row %}
        {% dnd_module path="../modules/cta-section.module" %}
        {% end_dnd_module %}
      {% end_dnd_row %}
    {% end_dnd_column %}
  {% end_dnd_section %}

{% end_dnd_area %}

{% endblock body %}
